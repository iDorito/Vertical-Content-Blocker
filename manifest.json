{
  "manifest_version": 3,
  "name": "Vertical Content Blocker",
  "version": "1.0",
  "description": "Blocks Reels, Shorts, TikTok, Snapchat Spotlight & vertical videos. Protects focus & kids.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*",
        "https://*.instagram.com/*",
        "https://*.facebook.com/*",
        "https://*.tiktok.com/*",
        "https://*.snapchat.com/*",
        "https://*.twitter.com/*",
        "https://*.x.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [],
  "host_permissions": [],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-48.png"
  }
}